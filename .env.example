# Add these keys to the repo root `.env.local` (e.g. barc/.env.local) next to your Next.js
# vars, or keep a copy under vet-rag-api/.env — see app/config.py load order.
#
# OpenAI (required for embeddings)
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: reduce dimensions for Pinecone index size (must match index config)
# OPENAI_EMBEDDING_DIMENSIONS=3072

# Vector backend: pinecone | weaviate
VECTOR_BACKEND=pinecone

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=vet-rag
# Optional: explicit host (recommended in production)
# PINECONE_HOST=https://your-index-xxxx.svc.region.pinecone.io

# Weaviate (when VECTOR_BACKEND=weaviate)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=
WEAVIATE_CLASS_NAME=VetChunk

# Retrieval
RETRIEVAL_TOP_K=8
SOURCE_QUALITY_ENABLED=true

# Query cache (LRU, in-process)
QUERY_CACHE_ENABLED=true
QUERY_CACHE_MAX_ENTRIES=256

# Optional re-ranking (requires sentence-transformers)
RERANK_ENABLED=false
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# API
API_HOST=0.0.0.0
API_PORT=8000

# Merck bulk crawl (pipeline_main.py)
MERCK_CRAWL_MAX_ARTICLES=2500
MERCK_CRAWL_MAX_VISITS=35000
MERCK_CRAWL_DELAY_S=1.0

# Agent /chat (JSON logs for evaluation)
AGENT_EVAL_LOG_PATH=logs/agent_interactions.jsonl
